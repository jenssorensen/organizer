{
  "name": "organizer",
  "version": "0.9.0",
  "type": "module",
  "files": [
    "bin/",
    "dist/",
    "server/"
  ],
  "bin": {
    "organizer": "./bin/organizer.mjs"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node server/devServer.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server/server.mjs",
    "release:local": "npm run build && NODE_ENV=production node server/server.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "lucide-react": "^0.542.0",
    "mermaid": "^11.14.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "uuid": ">=14.0.0"
  }
}
